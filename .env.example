# Path to a prebuilt tempo node binary. If unset, the harness looks for
# ../tempo/target/{release,debug}/tempo, then falls back to `cargo run`.
# TEMPO_BIN=/path/to/tempo/target/release/tempo

# Location of the tempo repo checkout (defaults to ../tempo).
# TEMPO_DIR=/path/to/tempo

# Genesis / chain spec (defaults to $TEMPO_DIR/scripts/genesis/staccato.json).
# TEMPO_GENESIS=/path/to/genesis.json
